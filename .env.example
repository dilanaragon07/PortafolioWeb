# =============================================================================
# Variables de entorno OPCIONALES para las herramientas de Claude Code
# instaladas en este entorno. Nada de esto es obligatorio: cada herramienta
# funciona con valores por defecto/local si no defines nada aquí.
# Copia este archivo a .env (o .env.local) y completa solo lo que vayas a usar.
# =============================================================================

# --- agent-browser (vercel-labs/agent-browser) --------------------------------
# Todo opcional. Sin esto, agent-browser usa Chrome local descargado en
# ~/.agent-browser/browsers/ y no necesita ninguna key.

# Reutilizar sesión/perfil de Chrome entre llamadas (login persistente)
# AGENT_BROWSER_SESSION=
# AGENT_BROWSER_PROFILE=

# Solo si usas el comando `agent-browser chat` (asistente IA integrado):
# AI_GATEWAY_API_KEY=            # Vercel AI Gateway — https://vercel.com/ai-gateway
# AI_GATEWAY_MODEL=anthropic/claude-sonnet-4.6

# Solo si quieres navegadores remotos en vez del Chrome local:
# BROWSERLESS_API_KEY=           # https://www.browserless.io/
# BROWSERBASE_API_KEY=           # https://www.browserbase.com/
# BROWSER_USE_API_KEY=           # https://browser-use.com/
# KERNEL_API_KEY=                # https://onkernel.com/
# (AgentCore/AWS Bedrock usa tus credenciales AWS normales, no una key nueva)

# Cifrado de estado de sesión guardado en disco (64 chars hex), solo si usas
# AGENT_BROWSER_RESTORE=true:
# AGENT_BROWSER_ENCRYPTION_KEY=

# --- code-review-graph (tirth8205/code-review-graph) ---------------------------
# Funciona 100% local (SQLite + tree-sitter) sin ninguna key. Estas son solo
# para activar búsqueda semántica con embeddings en la nube (opcional):
# GOOGLE_API_KEY=                # https://aistudio.google.com/apikey
# MINIMAX_API_KEY=
# CRG_OPENAI_API_KEY=
# CRG_OPENAI_BASE_URL=
# CRG_DATA_DIR=                  # ubicación custom de la BD (default: ~/.code-review-graph)
# CRG_EMBEDDING_MODEL=           # modelo de embeddings por defecto

# --- claude-mem (thedotmack/claude-mem) -----------------------------------------
# Usa el modelo/API que ya tienes configurado en Claude Code por defecto
# (provider=claude, sin key adicional). Solo necesitas variables extra si
# eliges otro proveedor de LLM para la compresión de memoria:
# CLAUDE_MEM_WELCOME_HINT_ENABLED=false   # desactiva el hint de bienvenida

# --- impeccable (pbakaus/impeccable) --------------------------------------------
# 100% local y determinista (46 reglas de detección). No requiere ninguna key.

# =============================================================================
# NADA de esto afecta tu app (Next.js / React / Framer Motion). Si tu proyecto
# necesita sus propias variables (analytics, CMS, etc.) añádelas por separado.
# =============================================================================
